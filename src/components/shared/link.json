{
  "collectionName": "components_shared_links",
  "info": {
    "displayName": "Link",
    "icon": "link",
    "description": "Navigation link with optional icon and custom styling"
  },
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "href": {
      "type": "string",
      "required": true
    },
    "target": {
      "type": "enumeration",
      "enum": ["_self", "_blank"],
      "default": "_self"
    },
    "color": {
      "type": "customField",
      "customField": "plugin::color-picker.color"
    },
    "backgroundColor": {
      "type": "customField",
      "customField": "plugin::color-picker.color"
    },
    "icon": {
      "type": "component",
      "component": "shared.icon",
      "repeatable": false
    }
  }
}
