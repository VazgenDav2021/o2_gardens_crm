{
  "collectionName": "components_shared_buttons",
  "info": {
    "displayName": "Button",
    "icon": "cursor",
    "description": "Clickable button with optional icon and custom colors"
  },
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "href": {
      "type": "string"
    },
    "target": {
      "type": "enumeration",
      "enum": ["_self", "_blank"],
      "default": "_self"
    },
    "backgroundColor": {
      "type": "customField",
      "customField": "plugin::color-picker.color"
    },
    "color": {
      "type": "customField",
      "customField": "plugin::color-picker.color"
    },
    "borderColor": {
      "type": "customField",
      "customField": "plugin::color-picker.color"
    },
    "icon": {
      "type": "component",
      "component": "shared.icon",
      "repeatable": false
    }
  }
}
